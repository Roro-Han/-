local p=game:GetService("Players").LocalPlayer local function f(t) if t:IsA("Tool") then local i=t:FindFirstChild("Info") if i and i:IsA("ModuleScript") then local o,d=pcall(require,i) if o then d.ammo=999999 d.max_ammo=999999 end end end end p.CharacterAdded:Connect(function(c) c.ChildAdded:Connect(f) end) if p.Character then for _,v in pairs(p.Character:GetChildren()) do f(v) end p.Character.ChildAdded:Connect(f) end for _,v in pairs(p.Backpack:GetChildren()) do f(v) end p.Backpack.ChildAdded:Connect(f)
